# Local development environment variables for wrangler dev
# Copy to .dev.vars (preferred) or set inline before pnpm dev

# Logging / runtime
NODE_ENV=dev
DEPLOY_RUNTIME=cf

# Drizzle dialect: libsql (default) or d1
DB_TYPE=libsql

# LibSQL (used when DB_TYPE=libsql)
LIBSQL_URL=file:./src/database/data.db
LIBSQL_AUTH_TOKEN=

# Cloudflare D1 (used when DB_TYPE=d1)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_API_TOKEN=
